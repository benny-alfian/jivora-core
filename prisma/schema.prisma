generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ===============================
// ENUMS
// ===============================
//

enum GlobalRole {
  FOUNDER
  PLATFORM_ADMIN
  SUPPORT_ADMIN
}

enum TenantRole {
  OWNER
  MANAGER
  STAFF
  CASHIER
}

enum Plan {
  BASIC
  GROWTH
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  MAINTENANCE
}

enum TransactionStatus {
  PAID
  PENDING
  CANCELLED
}

//
// ===============================
// PLATFORM USER (GLOBAL LEVEL)
// ===============================
//

model PlatformUser {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      GlobalRole
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

//
// ===============================
// TENANT (BUSINESS)
// ===============================
//

model Tenant {
  id        String        @id @default(uuid())
  name      String
  plan      Plan          @default(BASIC)
  status    TenantStatus  @default(ACTIVE)

  users        User[]
  products     Product[]
  transactions Transaction[]
  auditLogs    AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ===============================
// TENANT USER
// ===============================
//

model User {
  id        String      @id @default(uuid())
  name      String
  email     String
  password  String
  role      TenantRole  @default(STAFF)

  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
}

//
// ===============================
// PRODUCT
// ===============================
//

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Int
  stock     Int

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ===============================
// TRANSACTION
// ===============================
//

model Transaction {
  id        String            @id @default(uuid())
  total     Int
  status    TransactionStatus @default(PAID)

  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// ===============================
// AUDIT LOG (FOUNDATION)
// ===============================
//

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entity      String
  entityId    String?
  performedBy String
  metadata    Json?

  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}