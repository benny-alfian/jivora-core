run = "npm run dev"
modules = ["nodejs-20"]

[nix]
channel = "stable-23_11"

[deployment]
run = ["npm", "run", "start"]

[[ports]]
localPort = 3000
externalPort = 3000

[agent]
expertMode = true

[userenv]

[userenv.shared]
JWT_SECRET = "jivora-super-secret-jwt-key-change-in-production"
PORT = "3000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"
